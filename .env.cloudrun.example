# Environment Configuration for Cloud Run Deployment
# Copy this file to .env.cloudrun and fill in your values

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Redis (Cloud Memorystore)
# Will be auto-populated by deployment script
REDIS_URL=redis://MEMORYSTORE_IP:6379

# Cloud Storage
S3_WEATHER_BUCKET=gs://your-project-id-weather-data

# Optional: AWS S3 (if using S3 instead of Cloud Storage)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_DEFAULT_REGION=us-east-1

# Application
NODE_ENV=production
PORT=3001

# Celery
CELERY_BROKER_URL=redis://MEMORYSTORE_IP:6379
CELERY_RESULT_BACKEND=redis://MEMORYSTORE_IP:6379

# Optional: Database (if adding Cloud SQL)
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance

# Optional: Custom domain
# FRONTEND_URL=https://weather.yourdomain.com
# BACKEND_URL=https://api.weather.yourdomain.com
