# AI Weather Analytics Platform - Environment Configuration

# S3 Storage Configuration (optional)
# If S3_WEATHER_BUCKET is set, processed Zarr files will be uploaded to S3
# Leave empty to keep data in local /tmp only
S3_WEATHER_BUCKET=

# AWS Credentials (required if S3_WEATHER_BUCKET is set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Redis Configuration (override defaults if needed)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Backend API Configuration
# PORT=3001
# NODE_ENV=production
